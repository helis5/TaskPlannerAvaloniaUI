<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TaskPlanner.SubTaskControl">
    <UserControl.Styles>
        <StyleInclude Source="/SubTaskControlStyles.axaml"/>
    </UserControl.Styles>
    <Border x:Name="SubTask">
        <!--<Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Переместить вправо" Click="OnMoveToRight"/>
                <MenuItem Header="Переместить влево" Click="OnMoveToLeft"/>
                ~1~<MenuItem Header="Переместить вправо" Click="OnMoveToRight"/>@1@
                
            </ContextMenu>
        </Border.ContextMenu>-->
        <StackPanel Orientation="Vertical">
            <DockPanel>
                <Ellipse Width="8" Height="8" Margin="0 0 10 0" Fill="#E8EAF0" VerticalAlignment="Center"/>
                <TextBox x:Name="SubTaskText" HorizontalAlignment="Left" Watermark="Пункт"/>
                <Button HorizontalAlignment="Right" Click="OnDeleteClick">x</Button>
            </DockPanel>
        </StackPanel>
    </Border>
</UserControl>
