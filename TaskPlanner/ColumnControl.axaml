<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:TaskPlanner"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TaskPlanner.ColumnControl">
    <UserControl.Styles>
        <StyleInclude Source="/ColumnControlStyles.axaml"/>
    </UserControl.Styles>
    <Border Classes="BaseBorder">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="TitleText"/>
                <Button Content="x" Click="OnDeleteClick"/>
            </StackPanel>
            
            <TextBlock x:Name="ColumnID"/>
            <Button Click="OnAddCardClick">Новая задача</Button>
            <TextBlock>Строка 1</TextBlock>
            <TextBlock>Строка 2</TextBlock>
            <ItemsControl x:Name="Tasks">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:TaskCard">
                        <models:TaskCardControl/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
